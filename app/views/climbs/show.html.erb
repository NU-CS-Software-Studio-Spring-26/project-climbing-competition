<% content_for :title, "Climb Details" %>

<section class="page-header text-center">
  <h1 class="page-title">climb details</h1>
</section>

<div class="action-row mb-2 d-flex gap-2 flex-wrap align-items-center">
  <%= link_to competition_path(@competition), class: "back-arrow-text-link" do %>
    <span aria-hidden="true">←</span>
    back to competition details
  <% end %>
</div>

<div class="detail-panel p-4 mb-3">
  <p class="detail-item mb-2"><span>Competition:</span> <%= @competition.name %></p>
  <p class="detail-item mb-0"><span>Climb ID:</span> <%= @climb_id %></p>
</div>

