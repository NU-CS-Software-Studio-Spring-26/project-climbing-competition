<%= form_with(model: competition, html: { class: "board-form" }) do |form| %>
  <% if competition.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <h2 class="h6"><%= pluralize(competition.errors.count, "error") %> prevented this competition from being saved:</h2>
      <ul class="mb-0">
        <% competition.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Example: Regional Boulder Jam" %>
  </div>

  <div class="mb-3">
    <%= form.label :date, class: "form-label" %>
    <%= form.date_field :date, class: "form-control" %>
  </div>

  <div class="action-row d-flex gap-2 flex-wrap">
    <%= form.submit "Save Competition", class: "btn btn-board-primary" %>
    <%= link_to "Cancel", competitions_path, class: "btn btn-board-secondary" %>
  </div>
<% end %>
