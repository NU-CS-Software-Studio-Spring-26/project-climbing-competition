<%= form_with(model: competition) do |form| %>
  <% if competition.errors.any? %>
    <div class="alert alert-danger" role="alert">
      <h2 class="h6"><%= pluralize(competition.errors.count, "error") %> prevented this competition from being saved:</h2>
      <ul class="mb-0">
        <% competition.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= form.label :name, class: "form-label" %>
    <%= form.text_field :name, class: "form-control", placeholder: "Example: Regional Boulder Jam" %>
  </div>

  <div class="mb-3">
    <%= form.label :date, class: "form-label" %>
    <%= form.date_field :date, class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= form.label :owner_id, "Owner", class: "form-label" %>
    <%= form.select :owner_id,
          User.order(:username).map { |u| [u.username, u.id] },
          { include_blank: "— None —" },
          class: "form-select" %>
  </div>

  <div>
    <%= form.submit "Save Competition", class: "btn btn-success" %>
  </div>
<% end %>
