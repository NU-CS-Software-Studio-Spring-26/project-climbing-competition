<% content_for :title, "Edit Competition" %>

<section class="page-header">
  <h1 class="mb-1">Edit Competition</h1>
  <p class="text-muted mb-0">Update the competition details.</p>
</section>

<div class="detail-panel p-4 mb-3">
  <%= render "form", competition: @competition %>
</div>

<div class="d-flex gap-2 flex-wrap">
  <%= link_to "Back to Competition", @competition, class: "btn btn-outline-secondary" %>
  <%= link_to "Home", competitions_path, class: "btn btn-outline-secondary" %>
</div>
