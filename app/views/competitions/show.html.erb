<% content_for :title, "Competition Details" %>

<section class="page-header text-center">
  <h1 class="page-title">competition details</h1>
</section>

<div class="action-row mb-2 d-flex gap-2 flex-wrap align-items-center">
  <%= link_to competitions_path, class: "back-arrow-text-link" do %>
    <span aria-hidden="true">←</span>
    back to all competitions
  <% end %>
</div>

<div class="detail-panel p-4 mb-3">
  <h2 class="detail-heading"><%= @competition.name %></h2>
  <p class="detail-item mb-0"><span>Ends:</span> <%= @competition.date %></p>
</div>

<div class="action-row d-flex flex-column gap-3 align-items-start">
  <%= link_to competition_climb_path(@competition, 1), class: "climb-card-link" do %>
    <span class="climb-card-title">View a Climb</span>
    <span class="climb-card-subtitle">Open climb preview for this event</span>
  <% end %>
</div>
